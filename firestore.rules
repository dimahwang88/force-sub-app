rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Classes: authenticated users can read; admins can fully write;
    // regular users can only update bookedCount (for booking/cancellation)
    match /classes/{classId} {
      allow read: if request.auth != null;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() ||
        (request.auth != null &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['bookedCount']));
    }

    // Bookings: users can read/create/update their own bookings;
    // admins can read all bookings (for dashboard attendance data)
    match /bookings/{bookingId} {
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // Users: users can read/write their own profile;
    // admins can read all user profiles (for dashboard)
    match /users/{userId} {
      allow read: if request.auth != null &&
        (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Admin invite codes: anyone authenticated can read (for sign-up validation);
    // only admins can create/delete; sign-up flow can update (mark as used)
    match /adminCodes/{code} {
      allow read: if request.auth != null;
      allow create, delete: if isAdmin();
      allow update: if request.auth != null &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usedBy', 'usedAt']);
    }
  }
}
