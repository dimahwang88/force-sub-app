rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Selfie images: users can read/write only their own selfie.
    // Path: selfies/{userId}.jpg
    match /selfies/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Class group photos: any authenticated user can read;
    // only admins can upload/delete (enforced in app code via isAdmin check).
    // firestore.get() is not available in Storage rules, so we use
    // request.auth.token.admin custom claim if set, otherwise rely on app-level enforcement.
    match /classPhotos/{classId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }
  }
}
